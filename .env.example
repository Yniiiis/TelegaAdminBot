BOT_TOKEN=your_bot_token_from_botfather

# Уровень логов: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Пароль для команды /admin (вводится вторым сообщением после /admin)
ADMIN_PASSWORD=your_secure_password

# Список user_id через запятую; если задан — /admin только для этих id (плюс пароль)
# ADMIN_USER_IDS=123456789,987654321

# Антиспам (на процесс; при нескольких воркерах нужен общий стор)
RATE_WINDOW_SEC=30
RATE_MAX_EVENTS=25
CHECK_SUB_COOLDOWN_SEC=5
GET_ACCESS_COOLDOWN_SEC=2

# Повтор при временной блокировке SQLite
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY_SEC=0.15

# Публичный канал: username без @ или с @ (для проверки подписки и ссылки Subscribe)
TELEGRAM_CHANNEL=mychannel
# Если канал только по id (-100...), задайте явную ссылку-приглашение:
# TELEGRAM_CHANNEL_SUBSCRIBE_URL=https://t.me/+xxxx
